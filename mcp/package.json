{
  "name": "@flexgate/mcp-server",
  "version": "0.1.0",
  "description": "Flexgate MCP Interface — exposes proxy logs, config, incidents, and analytics to AI agents via the Model Context Protocol",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "flexgate-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
