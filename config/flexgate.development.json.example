{
  "server": {
    "port": 3000,
    "host": "localhost",
    "environment": "development"
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "flexgate_dev",
    "user": "flexgate",
    "password": "flexgate",
    "ssl": false,
    "poolMin": 2,
    "poolMax": 5
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0
  },
  "security": {
    "corsOrigins": ["*"],
    "corsEnabled": true,
    "rateLimitEnabled": false,
    "rateLimitWindowMs": 60000,
    "rateLimitMaxRequests": 1000
  },
  "logging": {
    "level": "debug",
    "format": "simple",
    "destination": "console",
    "maxFiles": 5,
    "maxSize": "10m"
  },
  "monitoring": {
    "metricsEnabled": true,
    "prometheusPort": 9090,
    "healthCheckInterval": 60000
  }
}
