{
  "env": {
    "node": true,
    "es6": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "indent": ["error", 2, { "SwitchCase": 1 }],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["**/*.ts"],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
      },
      "env": {
        "node": true
      },
      "globals": {
        "NodeJS": "readonly"
      },
      "rules": {
        "indent": "off",
        "no-unused-vars": "off",
        "no-undef": "off"
      }
    },
    {
      "files": [
        "**/__tests__/**/*.{js,ts}",
        "**/*.test.{js,ts}",
        "**/*.spec.{js,ts}",
        "tests/**/*.{js,ts}",
        "test-files-to-copy/**/*.{js,ts}"
      ],
      "env": {
        "jest": true
      },
      "rules": {
        "no-undef": "off"
      }
    },
    {
      "files": ["bin/*.js"],
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ]
}
