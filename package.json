{
  "name": "flexgate-proxy-workspace",
  "private": true,
  "description": "FlexGate Proxy — npm workspace root for Go binary distribution packages",
  "workspaces": [
    "npm/flexgate-proxy",
    "npm/packages/*"
  ],
  "scripts": {
    "version-sync": "node npm/scripts/sync-versions.js",
    "benchmark":          "BENCHMARK_API_URL=${BENCHMARK_API_URL:-http://localhost:8080} node benchmarks/run.js",
    "benchmark:full":     "BENCHMARK_API_URL=${BENCHMARK_API_URL:-http://localhost:8080} node benchmarks/run.js --profile full",
    "benchmark:scenario": "BENCHMARK_API_URL=${BENCHMARK_API_URL:-http://localhost:8080} node benchmarks/run.js --scenario",
    "bench:rerun":        "./start.sh --rerun",
    "bench:rerun:baseline":   "./start.sh --rerun --scenario baseline",
    "bench:rerun:nginx":      "./start.sh --rerun --scenario nginx",
    "bench:rerun:haproxy":    "./start.sh --rerun --scenario haproxy",
    "bench:rerun:full":       "./start.sh --rerun --profile full"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tapas100/flexgate-proxy.git"
  },
  "author": {
    "name": "tapas100",
    "email": "mahanta.tapas9@gmail.com",
    "url": "https://github.com/tapas100"
  },
  "license": "MIT"
}
